{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 2,
	"settings": {
		"appearanceTools": true,
		"color": {
			"custom": false,
			"defaultPalette": false,
			"palette": [
				{
					"slug": "deep-ocean",
					"color": "#006b8f",
					"name": "Deep Ocean"
				},
				{
					"slug": "forest",
					"color": "#00a878",
					"name": "Forest"
				},
				{
					"slug": "sunset",
					"color": "#ff7a1a",
					"name": "Sunset"
				},
				{
					"slug": "cream",
					"color": "#fff8ea",
					"name": "Cream"
				},
				{
					"slug": "charcoal",
					"color": "#10212b",
					"name": "Charcoal"
				},
				{
					"slug": "sky",
					"color": "#b9f3ff",
					"name": "Sky"
				},
				{
					"slug": "clay",
					"color": "#ff4d6d",
					"name": "Clay"
				}
			]
		},
		"layout": {
			"contentSize": "1120px",
			"wideSize": "1360px"
		},
		"spacing": {
			"spacingScale": {
				"steps": 0
			},
			"spacingSizes": [
				{
					"slug": "20",
					"size": "0.5rem",
					"name": "2"
				},
				{
					"slug": "30",
					"size": "1rem",
					"name": "3"
				},
				{
					"slug": "40",
					"size": "1.5rem",
					"name": "4"
				},
				{
					"slug": "50",
					"size": "2rem",
					"name": "5"
				},
				{
					"slug": "60",
					"size": "3rem",
					"name": "6"
				},
				{
					"slug": "70",
					"size": "4rem",
					"name": "7"
				}
			]
		},
		"typography": {
			"fluid": false,
			"fontFamilies": [
				{
					"slug": "system",
					"name": "System",
					"fontFamily": "-apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif"
				}
			],
			"fontSizes": [
				{
					"slug": "small",
					"size": "0.875rem",
					"name": "Small"
				},
				{
					"slug": "medium",
					"size": "1rem",
					"name": "Medium"
				},
				{
					"slug": "large",
					"size": "1.375rem",
					"name": "Large"
				},
				{
					"slug": "x-large",
					"size": "2rem",
					"name": "Extra Large"
				},
				{
					"slug": "hero",
					"size": "3.5rem",
					"name": "Hero"
				}
			]
		}
	},
	"styles": {
		"color": {
			"background": "#fff8ea",
			"text": "#10212b"
		},
		"elements": {
			"button": {
				"border": {
					"radius": "6px"
				},
				"color": {
					"background": "#ff7a1a",
					"text": "#10212b"
				},
				"typography": {
					"fontWeight": "700"
				}
			},
			"link": {
				"color": {
					"text": "#006b8f"
				}
			}
		},
		"spacing": {
			"blockGap": "1.5rem"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--system)",
			"fontSize": "var(--wp--preset--font-size--medium)",
			"lineHeight": "1.6"
		}
	}
}
